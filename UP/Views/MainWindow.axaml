<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UP.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:UP.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="UP.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="UP">
    <DrawerPage>
        <DrawerPage.DrawerHeader>
            <Border Background="#C8966E" Padding="20,24,20,16">
                <StackPanel Spacing="4" >
                    <TextBlock Text="Shut I Korol"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               />
                    <TextBlock Text="{Binding GreetingText}"
                               Foreground="#FDF8F5"
                               FontSize="12"
                               />
                </StackPanel>
            </Border>
        </DrawerPage.DrawerHeader>
        <DrawerPage.Drawer>
            <StackPanel Spacing="8" Margin="12" Width="200" >

                <Button Background="Transparent" BorderThickness="0"
                        Padding="8" CornerRadius="8"
                        ToolTip.Tip="Каталог книг"
                        Command="{Binding GoToCatalogCommand}">
                    <Image Source="/Assets/01_catalog.png" Width="32" Height="32"
                           VerticalAlignment="Center"/>
                </Button>

                <Button Background="Transparent" BorderThickness="0"
                        Padding="8" CornerRadius="8"
                        ToolTip.Tip="Списки книг"
                        Command="{Binding GoToListsCommand}">
                    <Image Source="/Assets/02_lists.png" Width="32" Height="32"
                           VerticalAlignment="Center"/>
                </Button>

                <Button Background="Transparent" BorderThickness="0"
                        Padding="8" CornerRadius="8"
                        ToolTip.Tip="Профиль"
                        Command="{Binding GoToProfileCommand}">
                        
                    <Image Source="/Assets/06_profile.png" Width="32" Height="32"
                           VerticalAlignment="Center"/>
                </Button>

                <Button Background="Transparent" BorderThickness="0"
                        Padding="8" CornerRadius="8"
                        ToolTip.Tip="Страница автора"
                        IsVisible="{Binding IsAuthor}"
                        Command="{Binding GoToAuthorPageCommand}">
                    <Image Source="/Assets/04_author.png" ToolTip.Tip="Страница автора" Width="32" Height="32"
                           VerticalAlignment="Center"/>
                </Button>

                <Button Background="Transparent" BorderThickness="0"
                        Padding="8" CornerRadius="8"
                        ToolTip.Tip="Администрирование"
                        IsVisible="{Binding IsAdmin}"
                        Command="{Binding GoToAdminCommand}">
                    <Image Source="/Assets/03_admin.png" Width="32" Height="32"
                           VerticalAlignment="Center"/>
                </Button>

                <Button Background="Transparent" BorderThickness="0"
                        Padding="8" CornerRadius="8"
                        ToolTip.Tip="Аккаунт заморожен"
                        IsVisible="{Binding IsFrozen}"
                        Command="{Binding GoToFreezeWarningCommand}">
                    <Image Source="/Assets/05_frozen.png" Width="32" Height="32"
                           VerticalAlignment="Center"/>
                </Button>

            </StackPanel>
        </DrawerPage.Drawer>
        <DrawerPage.Content>
            <NavigationPage x:Name="NavPage" >
                <NavigationPage.TopCommandBar>
                    <CommandBar Background="#FDF8F5">
                        
                    </CommandBar>
                </NavigationPage.TopCommandBar>
            </NavigationPage>
        </DrawerPage.Content>
            
        </DrawerPage>
</Window>
