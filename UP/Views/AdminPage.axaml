<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:UP.Views"
             xmlns:adminViews="clr-namespace:UP.Views.AdminViews"
             xmlns:viewModels="clr-namespace:UP.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UP.Views.AdminPage">
    
        <Grid RowDefinitions="Auto,*">
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding AuthorBidClickCommand}"   Content="AuthorBid"
                                Height="38" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#C8966E" Foreground="White"
                                CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
                        <Button Command="{Binding FrozenBidClickCommand}"   Content="FrozenBid"
                                Height="38" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#C8966E" Foreground="White"
                                CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
                        <Button Command="{Binding FrozenListClickCommand}" Content="FrozenList"
                                Height="38" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#C8966E" Foreground="White"
                                CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
                        <Button Command="{Binding ReportsClickCommand}"   Content="Reports"
                                Height="38" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#C8966E" Foreground="White"
                                CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
                        <Button Command="{Binding UsersListClickCommand}"   Content="UsersList"
                                Height="38" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#C8966E" Foreground="White"
                                CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
                
             
        </Grid>
</ContentPage>
