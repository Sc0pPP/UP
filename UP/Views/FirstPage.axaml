<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:UP.Views"
             xmlns:viewModels="clr-namespace:UP.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UP.Views.FirstPage"
             >
    <NavigationPage.TopCommandBar>
        <CommandBar Background="#FDF8F5">
                        
        </CommandBar>
    </NavigationPage.TopCommandBar>
    <Grid RowDefinitions="50,*">
        
        <StackPanel  HorizontalAlignment="Left" Height="100" Orientation="Horizontal"
                    VerticalAlignment="Center">
            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,12,0">
                <TextBlock Text="Фильтр по автору" Foreground="#7A6A6A" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBox Width="150" Name="Author" 
                         CornerRadius="6" BorderBrush="#E0C8BC" Height="22"
                         Text="{Binding SearchAuthor}"
                         />
            </StackPanel>
            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock Text="Фильтр по названию" Foreground="#7A6A6A" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBox Width="150" Name="Master" 
                         CornerRadius="6" BorderBrush="#E0C8BC" Height="22"
                         Text="{Binding SearchName}"
                         />
            </StackPanel>
            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock Text="Фильтр по Жанру" Foreground="#7A6A6A" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <ComboBox Text="Жанр"
                          ItemsSource="{Binding GenresList}"
                          SelectedItem="{Binding SelectedGenre}"
                          HorizontalAlignment="Center"
                          Width="120"
                          />
            </StackPanel>
            </StackPanel>
        <Border Grid.Row="1" BorderThickness="1" BorderBrush="#E0C8BC" Background="White"
                Margin="10" CornerRadius="10">
           <ListBox ScrollViewer.HorizontalScrollBarVisibility="Disabled" x:Name="prod"
                    ItemsSource="{Binding BooksIS}"
                    SelectedItem="{Binding SelectedBook}"
                    Margin="10" Background="Transparent">
               <ListBox.ItemTemplate>
                   <DataTemplate>
                       <Border Background="White" BorderBrush="#F0E0D6" BorderThickness="1"
                               CornerRadius="8" Padding="12" Margin="6">
                           <StackPanel Orientation="Vertical" Spacing="0">
                               <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                          FontSize="15" Foreground="#2D2D2D"/>
                               <TextBlock Text="{Binding AuthorNavigation.fio}" FontWeight="SemiBold"
                                          FontSize="15" Foreground="#2D2D2D"/>
                               <TextBlock Text="{Binding Description}" FontWeight="SemiBold"
                                          FontSize="13" Foreground="#2D2D2D"/>
                               <TextBlock Text="{Binding Review,StringFormat='{}Средняя рейтинг: {0} '}" FontWeight="SemiBold"
                                          FontSize="13" Foreground="#2D2D2D"/>
                               <ListBox ItemsSource="{Binding BookGenres}"
                                        Background="Transparent" BorderThickness="0">
                                   <ListBox.ItemTemplate>
                                       <DataTemplate>
                                           <StackPanel Spacing="2" Margin="0,2,0,2">
                                               <TextBlock Text="{Binding Genre.Genre1}"
                                                          Foreground="#5A4A4A" FontSize="13"/>
                                           </StackPanel>
                                       </DataTemplate>
                                   </ListBox.ItemTemplate>
                               </ListBox>
                               <Button Content="Подробнее" 
                                       Background="#C8966E" Foreground="White"
                                       CornerRadius="6" Padding="10,5" FontSize="13" Margin="0,10,0,0"
                                       Command="{Binding DataContext.CLickBookCommand,
                                       RelativeSource={RelativeSource AncestorType=ListBox}}"
                                       CommandParameter="{Binding}"
                                       />
                           </StackPanel>
                       </Border>
                   </DataTemplate>
               </ListBox.ItemTemplate>
               <ListBox.ItemsPanel>
                   <ItemsPanelTemplate>
                       <WrapPanel />
                   </ItemsPanelTemplate>
               </ListBox.ItemsPanel>
           </ListBox>
       </Border>
   </Grid>
</ContentPage>
