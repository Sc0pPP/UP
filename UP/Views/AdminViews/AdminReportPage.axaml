<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UP.Views.AdminViews.AdminReportPage">
   <Grid RowDefinitions="Auto,*">
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding AuthorBidClickCommand}"   Content="AuthorBid"
                                Height="38" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#C8966E" Foreground="White"
                                CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
                        <Button Command="{Binding FrozenBidClickCommand}"   Content="FrozenBid"
                                Height="38" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#C8966E" Foreground="White"
                                CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
                        <Button Command="{Binding FrozenListClickCommand}" Content="FrozenList"
                                Height="38" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#C8966E" Foreground="White"
                                CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
                        <Button Command="{Binding ReportsClickCommand}"   Content="Reports"
                                Height="38" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#C8966E" Foreground="White"
                                CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
                        <Button Command="{Binding UsersListClickCommand}"   Content="UsersList"
                                Height="38" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#C8966E" Foreground="White"
                                CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
                        <Button Command="{Binding ApproveClickCommand}"   Content="Approve"
                                Height="38" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#7FB07A" Foreground="White"
                                CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
                        <Button Command="{Binding DisApproveClickCommand}"   Content="DisApprove"
                                Height="38" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#C97A7A" Foreground="White"
                                CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
            <Border Grid.Row="1" BorderThickness="1" BorderBrush="#E0C8BC" Background="White"
                    Margin="10" CornerRadius="10">
                    <ListBox ScrollViewer.HorizontalScrollBarVisibility="Disabled" x:Name="prod"
                             ItemsSource="{Binding AllRL}"
                             SelectedItem="{Binding SelectedReport}"
                             Margin="10" Background="Transparent">
                            <ListBox.ItemTemplate>
                                    <DataTemplate>
                                            <Border Background="White" BorderBrush="#F0E0D6" BorderThickness="1"
                                                    CornerRadius="8" Padding="12" Margin="6">
                                                    <StackPanel Orientation="Vertical" Spacing="0">
                                                            <TextBlock Text="{Binding User.fio}" FontWeight="SemiBold"
                                                                       FontSize="15" Foreground="#2D2D2D"/>
                                                            <TextBlock Text="{Binding ReviewId,StringFormat='{}ReviewId: {0} '}" FontWeight="SemiBold"
                                                                       FontSize="15" Foreground="#2D2D2D"/>
                                                            <TextBlock Text="{Binding Cause}" FontWeight="SemiBold"
                                                                       FontSize="13" Foreground="#2D2D2D"/>
                                                            <TextBlock Text="{Binding IsChecked,StringFormat='{}Is Checked: {0} '}" FontWeight="SemiBold"
                                                                       FontSize="13" Foreground="#2D2D2D"/>
                                                            <TextBlock Text="{Binding ReportedUserId,StringFormat='{}ReportedUserId: {0} '}" FontWeight="SemiBold"
                                                                       FontSize="13" Foreground="#2D2D2D"/>
                                                            <TextBlock Text="{Binding BookId,StringFormat='{}BookId: {0} '}" FontWeight="SemiBold"
                                                                       FontSize="13" Foreground="#2D2D2D"/>
                                                    </StackPanel>
                                            </Border>
                                    </DataTemplate>
                            </ListBox.ItemTemplate>
                    </ListBox>
            </Border>
        </Grid>
</ContentPage>
