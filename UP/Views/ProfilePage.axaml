<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UP.Views.ProfilePage">
   <Grid Background="#FDF8F5">
    <Border HorizontalAlignment="Stretch"
            BorderThickness="1" BorderBrush="#E0C8BC"
            Background="White" Margin="20" CornerRadius="12">
        <Grid Margin="24" ColumnDefinitions="220,*,260">

          
            <StackPanel Grid.Column="0" Spacing="0" VerticalAlignment="Top">
                <TextBlock Text="Профиль" FontSize="13" FontWeight="SemiBold"
                           Foreground="#C8966E" Margin="0,0,0,14"/>

   
                <StackPanel Spacing="2" Margin="0,0,0,12">
                    <TextBlock Text="Логин" FontSize="11" Foreground="#B0A0A0"/>
                    <TextBlock Text="{Binding UserLogin}" FontSize="15"
                               FontWeight="SemiBold" Foreground="#3D2C2C"/>
                </StackPanel>


                <StackPanel Spacing="2" Margin="0,0,0,12">
                    <TextBlock Text="Email" FontSize="11" Foreground="#B0A0A0"/>
                    <TextBlock Text="{Binding Mail}" FontSize="14"
                               Foreground="#5A4A4A" TextWrapping="Wrap"/>
                </StackPanel>


                <StackPanel Spacing="2" Margin="0,0,0,20">
                    <TextBlock Text="Телефон" FontSize="11" Foreground="#B0A0A0"/>
                    <TextBlock Text="{Binding Phone}" FontSize="14"
                               Foreground="#5A4A4A"/>
                </StackPanel>


                <Border Height="1" Background="#F0E4DC" Margin="0,0,0,20"/>


                <Button Content="Стать автором"
                        Height="38" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        IsVisible="{Binding AuthorButton}"
                        Command="{Binding BidAuthorClickCommand}"
                        Background="#C8966E" Foreground="White"
                        CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>


            <StackPanel Grid.Column="1" Margin="24,0">
                <TextBlock Text="Мои отзывы" FontSize="13" FontWeight="SemiBold"
                           Foreground="#C8966E" Margin="0,0,0,14"/>
                <ListBox ItemsSource="{Binding Review}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FDF8F5" CornerRadius="8"
                                    BorderBrush="#E0C8BC" BorderThickness="1"
                                    Padding="14,10" Margin="0,0,0,10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Book.Name}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#3D2C2C"/>
                                    <TextBlock Text="{Binding ReviewText}"
                                               FontSize="12" Foreground="#7A6A6A"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="" FontSize="12"/>
                                        <TextBlock Text="{Binding Rating}"
                                                   FontSize="12" Foreground="#C8966E"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

  
            <StackPanel Grid.Column="2" VerticalAlignment="Top" Spacing="10"
                        IsVisible="{Binding FreezeTextVisible}">
                <Border Background="#FFF3ED" CornerRadius="10"
                        BorderBrush="#F5C4A8" BorderThickness="1"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="" FontSize="16"/>
                            <TextBlock Text="Аккаунт заблокирован"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#A0522D"/>
                        </StackPanel>
                        <Border Height="1" Background="#F5C4A8"/>
                        <TextBlock Text="Причина:" FontSize="11"
                                   Foreground="#B07050"/>
                        <TextBlock Text="{Binding FreezeText}"
                                   FontSize="13" Foreground="#5A4A4A"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Button Content="Подать на разморозку"
                        Height="40" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding BidFreezeClickCommand}"
                        Background="#C8966E" Foreground="White"
                        CornerRadius="8" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>

        </Grid>
    </Border>
</Grid>
</ContentPage>
